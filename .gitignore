# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
.turbo/
*.tsbuildinfo

# Per-package LICENSE / NOTICE copies — generated at pack time by
# scripts/copy-license-notice.mjs (each package's prepack). The root LICENSE
# and NOTICE are the single source of truth; these copies are build artifacts.
packages/*/LICENSE
packages/*/NOTICE

# Testing
coverage/
.nyc_output/
.vitest/

# Environment files (may contain secrets)
.env
.env.*
!.env.example

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local storage (accidental pnpm cache paths created on WSL when pnpm
# interprets Windows-style paths literally — the entire top-level dir is
# junk that gets regenerated on install; never commit).
C:\\*
/C:*
