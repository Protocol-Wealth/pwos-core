{
  "name": "pwos-core",
  "version": "0.1.0",
  "description": "Open source compliance-first AI operating system for SEC-registered investment advisers",
  "private": true,
  "license": "Apache-2.0",
  "author": "Protocol Wealth, LLC <opensource@protocolwealthllc.com>",
  "homepage": "https://pwos.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Protocol-Wealth/pwos-core.git"
  },
  "bugs": {
    "url": "https://github.com/Protocol-Wealth/pwos-core/issues"
  },
  "keywords": [
    "ria",
    "sec-compliance",
    "ai",
    "pii-detection",
    "audit-trail",
    "mcp",
    "wealth-management",
    "fintech"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "versions:check": "node scripts/check-version-constants.mjs",
    "lint:publish": "node scripts/check-publish-shape.mjs",
    "licenses:check": "npx license-checker-rseidelsohn --summary --production",
    "changeset": "changeset",
    "changeset:version": "changeset version && node scripts/sync-version-constants.mjs",
    "publish:check": "node scripts/check-publish-toolchain.mjs",
    "changeset:publish": "pnpm publish:check && pnpm build && pnpm lint:publish && changeset publish"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "js-yaml": ">=4.2.0",
      "vite": ">=6.4.3 <7"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "vite": "^6.4.3"
  }
}
