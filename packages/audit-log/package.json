{
  "name": "@protocolwealthos/audit-log",
  "version": "0.5.2",
  "description": "Append-only audit log with SHA-256 hash chaining for SEC Rule 204-2 compliance",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Protocol-Wealth/pwos-core/tree/main/packages/audit-log#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Protocol-Wealth/pwos-core.git",
    "directory": "packages/audit-log"
  },
  "bugs": {
    "url": "https://github.com/Protocol-Wealth/pwos-core/issues"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepack": "node ../../scripts/copy-license-notice.mjs && pnpm run build"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "@types/node": "^26.1.1",
    "@protocolwealthos/mcp-tools": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
