{
  "name": "@protocolwealthos/shared",
  "version": "0.1.0",
  "description": "Governance primitives for AI-assisted compliance systems: fail-closed HITL gate, disclosure-card schema (Zod + JSON Schema), and SHA-256 hash-chained provenance records. Framework-agnostic, zero runtime deps beyond zod.",
  "private": false,
  "license": "Apache-2.0",
  "homepage": "https://github.com/Protocol-Wealth/pwos-core/tree/main/packages/shared#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Protocol-Wealth/pwos-core.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/Protocol-Wealth/pwos-core/issues"
  },
  "keywords": [
    "ai-governance",
    "compliance",
    "hitl",
    "human-in-the-loop",
    "disclosure-card",
    "ai-disclosure",
    "provenance",
    "hash-chain",
    "tamper-evident",
    "sec-204-2",
    "ria"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./hitl": {
      "types": "./src/hitl/index.ts",
      "default": "./src/hitl/index.ts"
    },
    "./disclosure": {
      "types": "./src/disclosure/index.ts",
      "default": "./src/disclosure/index.ts"
    },
    "./provenance": {
      "types": "./src/provenance/index.ts",
      "default": "./src/provenance/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@types/node": "^25.8.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./hitl": {
        "types": "./dist/hitl/index.d.ts",
        "import": "./dist/hitl/index.js",
        "default": "./dist/hitl/index.js"
      },
      "./disclosure": {
        "types": "./dist/disclosure/index.d.ts",
        "import": "./dist/disclosure/index.js",
        "default": "./dist/disclosure/index.js"
      },
      "./provenance": {
        "types": "./dist/provenance/index.d.ts",
        "import": "./dist/provenance/index.js",
        "default": "./dist/provenance/index.js"
      }
    }
  }
}
