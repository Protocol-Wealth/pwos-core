{
  "name": "@protocolwealthos/holdings",
  "version": "0.2.0",
  "description": "Account / security / event-stream / daily-snapshot primitives for advisor portfolio data — immutable HoldingEvent log + materialized HoldingSnapshot, AccountBalance with inflow/outflow decomposition, custodian connection mirrors, scoped advisor access",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Protocol-Wealth/pwos-core/tree/main/packages/holdings#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Protocol-Wealth/pwos-core.git",
    "directory": "packages/holdings"
  },
  "bugs": {
    "url": "https://github.com/Protocol-Wealth/pwos-core/issues"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
